# ============================================================================
# AZURE DOCUMENT INTELLIGENCE CONFIGURATION (ENABLED BY DEFAULT)
# ============================================================================

# Azure Document Intelligence is ENABLED by default for document processing
# Includes OCR, form recognition, and invoice processing capabilities

# Optional: Document Intelligence configuration for medium production workloads
# document_intelligence_enabled = true                         # Default: true (enabled by default)
# document_intelligence_location = "eastus"                    # Default: uses resource group location
# document_intelligence_sku = "S0"                            # Default: "S0" (F0=free tier, S0=standard for production)
# document_intelligence_public_network_access_enabled = false # Default: false (private endpoint only)
# document_intelligence_private_endpoint_enabled = true       # Default: true (secure access)

# Store Document Intelligence keys in Key Vault for security
# store_document_intelligence_keys_in_keyvault = true        # Recommended for production
# key_vault_id = "/subscriptions/{subscription}/resourceGroups/{rg}/providers/Microsoft.KeyVault/vaults/{vault-name}"

# ============================================================================
# AZURE MACHINE LEARNING WORKSPACE CONFIGURATION (ENABLED BY DEFAULT)
# ============================================================================

# Azure Machine Learning is ENABLED by default for serverless model endpoints
# Includes ML workspace, Container Registry, and Application Insights

# Optional: ML workspace configuration for medium production workloads
# ml_workspace_enabled = true                              # Default: true (enabled by default)
# ml_workspace_location = "eastus"                         # Default: uses resource group location
# ml_workspace_public_network_access_enabled = false      # Default: false (private endpoint only)
# ml_workspace_private_endpoint_enabled = true            # Default: true (secure access)
ml_workspace_container_registry_sku = "Standard"          # Recommended: "Standard" for production workloads
ml_workspace_storage_replication_type = "GRS"             # Recommended: "GRS" for geo-redundant storage in production
# ml_workspace_application_insights_retention_days = 90   # Extended retention for production monitoring

# ============================================================================
# AZURE OPENAI SERVICE CONFIGURATION (ENABLED BY DEFAULT)
# ============================================================================

# Azure OpenAI is ENABLED by default with GPT-4.1 series models
# Deploys GPT-4.1-mini, GPT-4.1, and text-embedding-3-large

# Optional: OpenAI configuration for medium production workloads
# openai_enabled = true                         # Default: true (enabled by default)
# openai_location = "eastus"                    # Default: uses resource group location
# openai_sku = "S0"                            # Default: "S0"
# openai_public_network_access_enabled = false # Default: false (private endpoint only)
# openai_private_endpoint_enabled = true       # Default: true (secure access)

# AI model capacity for medium production
# deploy_gpt_4_1 = true                        # Default: true (GPT-4.1 deployed by default)
# gpt_4_1_mini_capacity = 30                   # 30K tokens per minute for medium production
# gpt_4_1_capacity = 20                        # 20K tokens per minute for medium production

# Text embedding for RAG and vector search
# deploy_text_embedding = true                 # Default: true (recommended for RAG)
# text_embedding_capacity = 120                # 120K tokens per minute for medium production

# Store OpenAI keys in Key Vault for security
# store_openai_keys_in_keyvault = true        # Recommended for production
# key_vault_id = "/subscriptions/{subscription}/resourceGroups/{rg}/providers/Microsoft.KeyVault/vaults/{vault-name}"

# ============================================================================
# STORAGE CONFIGURATION (ENABLED BY DEFAULT)
# ============================================================================

# Azure Storage containers for application data
storage_containers = ["airia-default", "airia-uploads", "airia-backups"]

# Optional: Storage blob retention policies (uncomment to enable data protection)
# NOTE: When enabled, deleted files are retained for the specified number of days (incurs storage costs)
# WARNING: Retention policies consume additional storage space and increase costs
# storage_blob_retention_days = 7              # Default: disabled - Days to retain deleted blobs (0 = disabled)
# storage_container_retention_days = 7         # Default: disabled - Days to retain deleted containers (0 = disabled)

# ============================================================================
# SECURITY & PRODUCTION READINESS
# ============================================================================

# - All databases use private endpoints (no public access)
# - Only Application Gateway has a public IP
# - SSL/TLS encryption throughout
# - Network security groups restrict access with proper outbound rules for AKS
# - Managed identities for service authentication
# - AKS applications can access storage via managed identity (no connection strings needed)
# - 2-zone deployment for high availability
# - Backup and disaster recovery configured
# - Sensitive variables MUST be set via environment variables (never hardcode in tfvars):
#   TF_VAR_postgresql_admin_password, TF_VAR_ssl_certificate_data, TF_VAR_ssl_certificate_password
#   (see SSL Certificate and PostgreSQL sections above for full export commands)

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================

# Before deploying to production:
# □ Update subscription_id to your production subscription
# □ Set sensitive values via environment variables (see sections above for full commands):
#     TF_VAR_postgresql_admin_password, TF_VAR_ssl_certificate_data, TF_VAR_ssl_certificate_password
# □ Update ssl_certificate_name with your certificate name
# □ Review and adjust node pool sizing based on expected load
# □ Enable geo-redundant backup if required for compliance
# □ Configure monitoring and alerting (outside of this Terraform)
# □ Set up CI/CD pipeline for application deployments
# □ Configure backup strategies for persistent data
# □ Review and adjust Cosmos DB TTL settings for your use case
# □ Enable only the AI services you need (each has cost implications)

# ============================================================================
# MEDIUM SIZING SUMMARY (from README.md)
# ============================================================================

# CPU Nodes: 5 nodes, 4-8 auto-scaling, Standard_E4as_v5 (4 vCPU, 32GB RAM)
# GPU Nodes (gpunodes): 2 nodes, Standard_NC4as_T4_v3 (4 vCPU, 28GB RAM, 1x NVIDIA T4)
# PostgreSQL: GP_Standard_D4s_v3 (4 vCPU, 16GB RAM), 128GB storage
# Application Gateway: 1 instance (scale up as needed)
# Storage: Multiple containers with managed identity access
# Network: Larger address spaces for production scale (10.0.0.0/21), 2-zone availability