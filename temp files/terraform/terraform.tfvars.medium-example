# Airia on Azure Infrastructure Configuration - Medium Production Deployment
# Deploys: AKS cluster, PostgreSQL database, Application Gateway, Azure OpenAI,
#          Document Intelligence, ML Workspace with Llama Vision, and associated networking
#
# This configuration is suitable for production workloads with moderate usage
# Based on Medium sizing specifications from README.md
#
# IMPORTANT: When copying to terraform.tfvars, ensure:
# - Replace placeholder values with your actual Azure subscription ID and desired configuration
# - All string values remain on single lines (no line breaks within quotes)
# - Keep # comment prefixes when leaving optional variables commented out
# - Only uncomment variables you want to override from defaults
# - Set sensitive variables like passwords via environment variables

# ============================================================================
# REQUIRED VARIABLES - YOU MUST UPDATE THESE VALUES
# ============================================================================

subscription_id = "your-azure-subscription-id"  # Replace with your Azure subscription ID
resource_prefix = "airia"                       # Prefix for all resource names
environment     = "prod"                        # Environment name (dev/staging/prod)

# postgresql_admin_password - REQUIRED: Set via environment variable, do not hardcode here
#   export TF_VAR_postgresql_admin_password="YourSecureP@ssword123"

# Resource tags for organization and billing
# owner       = "team@company.com"   # Contact email for these resources
# cost_center = "engineering"         # Cost center for billing/chargeback
# application = "airia"              # Default: "airia" - Application name tag

# ============================================================================
# INFRASTRUCTURE CONFIGURATION - MEDIUM PRODUCTION SIZING
# ============================================================================

# Azure region and versions
location = "eastus"
kubernetes_version = "1.34"
postgresql_version = "16"

# Network Configuration for Medium deployment
# Using larger address spaces for production scale
vnet_address_space = "10.0.0.0/21"              # 2,046 total IPs
aks_subnet_address_prefix = "10.0.0.0/22"       # 1,022 IPs for AKS (more pods/services)
private_endpoints_subnet_address_prefix = "10.0.4.0/24" # 254 IPs for private endpoints
appgw_subnet_address_prefix = "10.0.5.0/24"     # 254 IPs for Application Gateway

# ============================================================================
# KUBERNETES CLUSTER CONFIGURATION - MEDIUM PRODUCTION SIZING
# ============================================================================

# Default node pool - CPU optimized for general workloads
# Medium sizing from README.md: 5 nodes, 4-8 auto-scaling, Standard_D4ads_v5
default_node_pool = {
  name                 = "default"
  node_count           = 5                        # Medium production: 5 nodes
  auto_scaling_enabled = true
  min_count           = 4                        # Minimum 4 nodes for HA
  max_count           = 8                        # Scale up to 8 nodes for peak load
  vm_size             = "Standard_E4as_v5"       # 4 vCPU, 32GB RAM per node (AMD EPYC)
  zones               = ["1", "2"]               # Multi-zone for high availability
  max_pods            = 75
  max_surge           = "33%"
}

# GPU node pool - scaled up for medium production workloads
# Medium sizing: 2 GPU nodes with autoscaling up to 4
additional_node_pools = {
  gpu = {
    name                 = "gpunodes"
    vm_size              = "Standard_NC4as_T4_v3"  # 4 vCPU, 28GB RAM, 1x NVIDIA T4 (16GB)
    os_disk_size_gb      = 200
    os_disk_type         = "Managed"
    zones                = ["1", "2"]              # Multi-zone for HA
    auto_scaling_enabled = true
    min_count            = 2                       # Medium sizing: 2 GPU nodes minimum
    max_count            = 4                       # Up to 4 GPU nodes for scaling
    node_count           = 2
    node_taints          = ["gpu=true:NoSchedule"]
    node_labels = {
      "gpu" = "true"
    }
    max_pods             = 30
    max_surge            = "10%"
    gpu_driver           = "Install"               # Auto-install NVIDIA GPU drivers
  }
}

# ============================================================================
# APPLICATION GATEWAY & SSL CONFIGURATION (ENABLED BY DEFAULT)
# ============================================================================

# Health probe configuration (defaults target NGINX ingress controller)
# health_probe_path = "/healthz"                 # Default: "/healthz" - Health check endpoint path
# health_probe_port = 10254                      # Default: 10254 - NGINX health check port
# health_probe_host = ""                         # Default: "" - Host header (empty = pick from backend settings)

# Application Gateway sizing for medium production
appgw_sku_name = "Standard_v2"
appgw_sku_tier = "Standard_v2"
appgw_capacity = 1                               # 1 instance (increase for higher throughput)
nginx_internal_ip = "10.0.1.250"                # Static IP for nginx LoadBalancer

# SSL Certificate Configuration for HTTPS
# NOTE: Set sensitive certificate values via environment variables, do not hardcode here
ssl_certificate_name = "your-certificate-name"       # Certificate name (safe to set here)
# ssl_certificate_data and ssl_certificate_password - REQUIRED for HTTPS: Set via environment variables
#   export TF_VAR_ssl_certificate_data="<base64-encoded-pfx-certificate>"
#   export TF_VAR_ssl_certificate_password="<certificate-password>"

# ============================================================================
# POSTGRESQL DATABASE CONFIGURATION - MEDIUM PRODUCTION SIZING
# ============================================================================

postgresql_admin_username = "airiaadmin"
postgresql_sku_name = "GP_Standard_D4s_v3"      # 4 vCPUs, 16 GB RAM for medium production
postgresql_storage_mb = 131072                   # 128 GB storage
postgresql_backup_retention_days = 14            # 14 days backup retention for production
postgresql_geo_redundant_backup_enabled = false  # Enable for critical workloads requiring geo-redundancy
postgresql_auto_grow_enabled = true

# PostgreSQL maintenance window (UTC time) - scheduled for low usage period
postgresql_maintenance_window = {
  day_of_week  = 0    # Sunday
  start_hour   = 3    # 3:00 AM UTC
  start_minute = 0
}

# NOTE: PostgreSQL databases and extensions use comprehensive defaults from variables.tf
# Default databases (15): auditlog, conversations, dataingest, datastore, identity, keycloak,
#   marketplace, mcpgateway, metrics, platform, policyengine, rag, scheduler,
#   sectoolkit, usercredentialstore
# Default extensions: TIMESCALEDB, VECTOR, PGCRYPTO, UUID-OSSP, POSTGIS, PG_TRGM, FUZZYSTRMATCH, AGE, UNACCENT

